{
  "builds": [
    {
      "src": "api/refresh.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "data/**/*.json",
      "use": "@vercel/static"
    },
    {
      "src": "manifest.json",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/refresh",
      "dest": "/api/refresh.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
